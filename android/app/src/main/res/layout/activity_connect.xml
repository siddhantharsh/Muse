<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2E3440"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Logo and title -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MUSE"
        android:textColor="#88C0D0"
        android:textSize="24sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.3"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="connect to your laptop"
        android:textColor="#4C566A"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="48dp" />

    <!-- IP input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="laptop ip address"
        android:textColor="#D8DEE9"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/ipInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:hint="192.168.1.xxx"
        android:textColorHint="#4C566A"
        android:textColor="#ECEFF4"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="text"
        android:imeOptions="actionNext"
        android:singleLine="true"
        android:layout_marginBottom="24dp" />

    <!-- PIN input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="security pin"
        android:textColor="#D8DEE9"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/pinInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_bg"
        android:hint="4-digit PIN"
        android:textColorHint="#4C566A"
        android:textColor="#ECEFF4"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="number"
        android:maxLength="4"
        android:imeOptions="actionGo"
        android:singleLine="true"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="CONNECT"
        android:textColor="#2E3440"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:backgroundTint="#88C0D0"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open Muse on your laptop, go to\nSettings → Device Sync\nto find the IP address and PIN"
        android:textColor="#4C566A"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5" />

</LinearLayout>
